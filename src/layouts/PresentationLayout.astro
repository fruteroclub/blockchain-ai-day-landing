---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';
import type { WorkshopLocale } from '../data/workshops';

type Props = {
  title: string;
  description?: string;
  lang?: WorkshopLocale;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
};

const {
  title,
  description = 'AI x Blockchain Day workshop presentation.',
  lang = 'es',
  ogImage: ogImageProp,
  ogImageAlt = 'AI x Blockchain Day workshop presentation.',
  ogImageWidth = 1200,
  ogImageHeight = 630,
} = Astro.props as Props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = ogImageProp ? new URL(ogImageProp, Astro.site).href : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0E141D" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AI x Blockchain Day" />
    <meta property="og:locale" content={lang === 'es' ? 'es_MX' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImage && <meta property="og:image:height" content={String(ogImageHeight)} />}
    {ogImage && <meta property="og:image:alt" content={ogImageAlt} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {ogImage && <meta name="twitter:image:alt" content={ogImageAlt} />}
    <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="min-h-[100dvh] overflow-hidden bg-[var(--bg)] text-[var(--fg)]">
    <slot />
    <Analytics />
  </body>
</html>
