---
// Self-hosted fonts go here once the design identity picks them, e.g.:
//   import '@fontsource-variable/<face>';
// (Do not link Google Fonts via <link> in production.)
import '../styles/global.css';
import { getLang, useTranslations } from '../i18n/utils';
import { event } from '../i18n/ui';
import Analytics from '../components/Analytics.astro';

const lang = getLang(Astro);
const t = useTranslations(lang);

const canonical = new URL(Astro.url.pathname, Astro.site);
const esHref = new URL('/', Astro.site).href;
const enHref = new URL('/en/', Astro.site).href;

// OG image is produced in the design phase. Until then we omit the tag rather
// than reference a missing file.
const ogImage = undefined as string | undefined;

// schema.org/Event — real, known facts. Great SEO/AEO for an event landing.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: event.name,
  startDate: event.dateISOStart,
  endDate: event.dateISOEnd,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  description: t.meta.description,
  url: canonical.href,
  location: {
    '@type': 'Place',
    name: event.venue.name,
    address: {
      '@type': 'PostalAddress',
      streetAddress: event.venue.street,
      addressLocality: event.venue.locality,
      postalCode: event.venue.postalCode,
      addressRegion: event.venue.region,
      addressCountry: event.venue.country,
    },
  },
  offers: {
    '@type': 'Offer',
    url: event.registrationUrl,
    availability: 'https://schema.org/InStock',
  },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- First-visit language detection: default Spanish, send English devices
         to /en/. An explicit choice (stored on toggle click) always wins.
         Inline so it runs before paint and avoids a flash. -->
    <script is:inline>
      (function () {
        try {
          var KEY = 'baiday-lang';
          var p = location.pathname;
          var onEn = p === '/en' || p === '/en/';
          var stored = localStorage.getItem(KEY);
          if (!stored && !onEn) {
            var nav = (navigator.language || '').toLowerCase();
            if (nav.indexOf('en') === 0) location.replace('/en/');
          }
        } catch (e) {}
      })();
    </script>

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es" href={esHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={esHref} />

    <!-- Favicons are produced in the design phase; favicon.svg is a neutral placeholder. -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={event.name} />
    <meta property="og:locale" content={lang === 'es' ? 'es_MX' : 'en_US'} />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={t.meta.title} />
    <meta name="twitter:description" content={t.meta.description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-[100dvh]">
    <slot />
    <Analytics />

    <script>
      // Remember an explicit language choice when the toggle is clicked.
      document.querySelectorAll('[data-set-lang]').forEach((el) => {
        el.addEventListener('click', () => {
          try {
            localStorage.setItem('baiday-lang', el.getAttribute('data-set-lang') || 'es');
          } catch (e) {}
        });
      });

      // Scroll-reveal via IntersectionObserver (no scroll listeners).
      // Honors prefers-reduced-motion by showing everything immediately.
      const els = document.querySelectorAll('[data-reveal]');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
