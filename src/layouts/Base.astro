---
// Self-hosted display + mono faces (variable). Imported before global.css so
// the @font-face rules are registered before the token + base layers apply.
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import { getLang, useTranslations } from '../i18n/utils';
import { event } from '../i18n/ui';
import Analytics from '../components/Analytics.astro';

type Props = {
  title?: string;
  description?: string;
  esHref?: string;
  enHref?: string;
};

const {
  title,
  description,
  esHref: esHrefProp = '/',
  enHref: enHrefProp = '/en/',
} = Astro.props as Props;

const lang = getLang(Astro);
const t = useTranslations(lang);
const pageTitle = title ?? t.meta.title;
const pageDescription = description ?? t.meta.description;

const canonical = new URL(Astro.url.pathname, Astro.site);
const esHref = new URL(esHrefProp, Astro.site).href;
const enHref = new URL(enHrefProp, Astro.site).href;

const ogImage = new URL('/social/coworking-8am-og.png', Astro.site).href;

// schema.org/Event: real, known facts. Great SEO/AEO for an event landing.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: event.name,
  startDate: event.dateISOStart,
  endDate: event.dateISOEnd,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  description: pageDescription,
  url: canonical.href,
  location: {
    '@type': 'Place',
    name: event.venue.name,
    address: {
      '@type': 'PostalAddress',
      streetAddress: event.venue.street,
      addressLocality: event.venue.locality,
      postalCode: event.venue.postalCode,
      addressRegion: event.venue.region,
      addressCountry: event.venue.country,
    },
  },
  offers: {
    '@type': 'Offer',
    url: event.registrationUrl,
    availability: 'https://schema.org/InStock',
  },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- First-visit language detection: default Spanish, send English devices
         to /en/. An explicit choice (stored on toggle click) always wins.
         Inline so it runs before paint and avoids a flash. -->
    <script is:inline>
      (function () {
        try {
          var KEY = 'baiday-lang';
          var p = location.pathname;
          var onEn = p === '/en' || p.indexOf('/en/') === 0;
          var stored = localStorage.getItem(KEY);
          if (!stored && !onEn) {
            var nav = (navigator.language || '').toLowerCase();
            if (nav.indexOf('en') === 0) {
              var localized = p === '/recursos' || p === '/recursos/' ? '/en/resources/' : '/en/';
              location.replace(localized + location.search + location.hash);
            }
          }
        } catch (e) {}
      })();
    </script>

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es" href={esHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={esHref} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0E141D" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={event.name} />
    <meta property="og:locale" content={lang === 'es' ? 'es_MX' : 'en_US'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    {ogImage && <meta property="og:image:alt" content="AI x Blockchain Day runs from 10:00 to 17:00 in Mexico City." />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {ogImage && <meta name="twitter:image:alt" content="AI x Blockchain Day runs from 10:00 to 17:00 in Mexico City." />}

    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-[100dvh]">
    <slot />
    <Analytics />

    <script>
      // Remember an explicit language choice when the toggle is clicked.
      document.querySelectorAll('[data-set-lang]').forEach((el) => {
        el.addEventListener('click', () => {
          try {
            localStorage.setItem('baiday-lang', el.getAttribute('data-set-lang') || 'es');
          } catch (e) {}
        });
      });

      // Scroll-reveal via IntersectionObserver (no scroll listeners).
      // Honors prefers-reduced-motion by showing everything immediately.
      const els = document.querySelectorAll('[data-reveal]');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
