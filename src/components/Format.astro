---
// Format.astro: "what to expect" section.
// Asymmetric bento grid (CSS grid, mixed cell sizes) over t.format.items.
// Exactly one cell per item. Two cells carry visual variation: a tinted
// --surface-2 fill plus a faint Blueprint line texture (Talks, Cowork).
// Icons are Phosphor at bold weight. Cyan = structure/system per the locked
// dual-accent roles; rosa is intentionally absent here (no clear CTA job).

import { Icon } from 'astro-icon/components';
import Blueprint from './primitives/Blueprint.astro';
import { getLang, useTranslations } from '../i18n/utils';

const lang = getLang(Astro);
const t = useTranslations(lang);
const f = t.format;

// One Phosphor (bold) mark per idea, in item order. Length tracks f.items so
// no cell is ever iconless and no icon is orphaned.
const icons = [
  'ph:microphone-stage-bold',
  'ph:wrench-bold',
  'ph:monitor-play-bold',
  'ph:film-strip-bold',
  'ph:users-three-bold',
];

// Per-cell placement + treatment. `area` indexes the named grid template.
// `feature` cells get the tinted surface + Blueprint texture.
const cells = f.items.map((item, i) => ({
  item,
  icon: icons[i] ?? icons[icons.length - 1],
  area: `c${i + 1}`,
  feature: i === 0 || i === f.items.length - 1,
}));
---

<section
  id="formato"
  class="border-t border-[var(--border)] bg-[var(--bg)]"
>
  <div class="mx-auto max-w-[1200px] px-6 py-24 md:py-32">
    <h2
      class="max-w-[18ch] text-3xl leading-[1.05] tracking-tight text-[var(--fg)] sm:text-4xl md:text-5xl"
      data-reveal
    >
      {f.head}
    </h2>

    <div class="bento mt-14 md:mt-16" data-reveal>
      {cells.map(({ item, icon, area, feature }) => (
        <article
          class:list={[
            'cell relative flex flex-col overflow-hidden rounded-sm border p-7 md:p-8',
            feature
              ? 'border-[var(--accent-fill)]/30 bg-[var(--surface-2)]'
              : 'border-[var(--border)] bg-[var(--surface)]',
          ]}
          style={`--area:${area}`}
        >
          {feature && (
            <Blueprint
              class="pointer-events-none absolute -right-12 -top-12 h-44 w-44 text-[var(--accent)] opacity-[0.07]"
            />
          )}

          <Icon
            name={icon}
            class="relative h-8 w-8 text-[var(--accent)]"
            aria-hidden="true"
          />

          <h3 class="relative mt-6 text-xl tracking-tight text-[var(--fg)] md:text-2xl">
            {item.title}
          </h3>

          <p class="relative mt-3 max-w-[44ch] text-[15px] leading-relaxed text-[var(--fg-muted)]">
            {item.body}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Mobile-first: single column, equal cells. */
  .bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  /* Desktop: asymmetric 4-col bento. Talks (c1) leads wide, Cowork (c5)
     closes wide as the connective networking band; the middle three are
     compact. Named areas keep the placement explicit and gap-free. */
  @media (min-width: 768px) {
    .bento {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 1fr;
      gap: 1rem;
      grid-template-areas:
        "c1 c1 c2 c3"
        "c4 c5 c5 c5";
    }
    .cell {
      grid-area: var(--area);
    }
  }
</style>
