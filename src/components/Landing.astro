---
// ╔══════════════════════════════════════════════════════════════════════╗
// ║ PLACEHOLDER HOLDING PAGE — replaced during the design phase.          ║
// ║ The real landing (hero, program, sponsors, venue, FAQ, CTA) is built  ║
// ║ with the design brief + the design-taste-frontend skill. This minimal ║
// ║ neutral page only proves the layout / i18n / CTA wiring end to end.   ║
// ╚══════════════════════════════════════════════════════════════════════╝
import { getLang, useTranslations } from '../i18n/utils';
import { event } from '../i18n/ui';

const lang = getLang(Astro);
const t = useTranslations(lang);
---

<main class="mx-auto flex min-h-[100dvh] max-w-3xl flex-col items-center justify-center gap-8 px-6 py-24 text-center">
  <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--muted-foreground)]" data-reveal>
    {t.hero.kicker}
  </p>

  <h1 class="text-4xl font-bold tracking-tight md:text-6xl" data-reveal>
    {t.hero.head}
  </h1>

  <p class="max-w-[60ch] text-lg leading-relaxed text-[var(--muted-foreground)]" data-reveal>
    {t.hero.sub}
  </p>

  <div class="flex flex-wrap items-center justify-center gap-4" data-reveal>
    <a
      href={event.registrationUrl}
      target="_blank"
      rel="noopener"
      class="rounded-md bg-[var(--accent)] px-6 py-3 font-semibold text-white"
    >
      {t.hero.ctaPrimary}
    </a>
  </div>

  <address class="mt-6 not-italic text-sm text-[var(--muted-foreground)]" data-reveal>
    {event.venue.street} · {event.venue.locality} · {event.venue.region}
  </address>

  <p class="mt-12 rounded border border-dashed border-[var(--border)] px-4 py-2 text-xs text-[var(--muted-foreground)]">
    Scaffold ready. Design identity pending (design-taste-frontend).
  </p>
</main>
