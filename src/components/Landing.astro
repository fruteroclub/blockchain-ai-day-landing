---
// Landing.astro
// Composition root for AI x Blockchain Day. Wires the section components in
// reading order: Nav at the top, the content sections inside <main>, and the
// Footer at the bottom. Each child reads its own copy off the i18n dictionary,
// so this file stays locale-agnostic and renders identically for / and /en/.
import Nav from './Nav.astro';
import Hero from './Hero.astro';
import About from './About.astro';
import Program from './Program.astro';
import Format from './Format.astro';
import Sponsors from './Sponsors.astro';
import Venue from './Venue.astro';
import Faq from './Faq.astro';
import CtaBand from './CtaBand.astro';
import Footer from './Footer.astro';
---

<Nav />

<main>
  <Hero />
  <About />
  <Program />
  <Format />
  <Sponsors />
  <Venue />
  <Faq />
  <CtaBand />
</main>

<Footer />
