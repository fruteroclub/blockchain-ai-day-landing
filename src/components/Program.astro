---
// Program.astro
// The signature section: the four program zones rendered as a Lance Wyman
// CDMX Metro "line map". A single bold cyan line threads four station nodes;
// each station carries a Wyman pictogram, the zone name, a mono capacity
// chip, and a short description. Desktop is a horizontal line with four
// evenly spaced stations; below 768px it folds to a vertical line with the
// stations stacked down the left rail.
//
// Accent roles (locked): cyan = the structural line + station nodes + system
// labels. Rosa appears once, as the brand "+" mark in the eyebrow, the single
// rosa moment for this section.

import { getLang, useTranslations } from '../i18n/utils';
import Pictogram from './primitives/Pictogram.astro';

const lang = getLang(Astro);
const t = useTranslations(lang);
const p = t.program;

// Station index labels, blueprint-style (L1 .. L4) for the mono annotation.
const stationCode = (i: number) => `0${i + 1}`;
---

<section
  id="programa"
  class="relative border-t border-[var(--border)] bg-[var(--bg)] py-24 sm:py-32"
>
  <div class="mx-auto max-w-[1200px] px-6">
    <!-- Header -->
    <header class="max-w-2xl" data-reveal>
      <p class="mb-5 font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">
        <span class="text-[var(--cta)]">+</span> {p.eyebrow}
      </p>
      <h2 class="text-balance text-3xl leading-[1.05] sm:text-4xl md:text-5xl">
        {p.head}
      </h2>
      <p class="mt-5 max-w-xl text-base leading-relaxed text-[var(--fg-muted)]">
        {p.sub}
      </p>
    </header>

    <!-- Line map -->
    <div class="line-map mt-16 sm:mt-20" role="list" aria-label={p.head}>
      <!-- The connecting line is drawn by ::before on .line-map (see <style>) -->
      {p.zones.map((zone, i) => (
        <article
          class="station"
          role="listitem"
          data-reveal
          style={`--reveal-delay:${i * 90}ms`}
        >
          <!-- Station node: pictogram inside a cyan-ringed disc sitting on the line -->
          <div class="station-node">
            <span class="node-ring">
              <Pictogram
                name={zone.key}
                class="h-6 w-6 text-[var(--accent)] sm:h-7 sm:w-7"
                title={zone.name}
              />
            </span>
          </div>

          <!-- Station body -->
          <div class="station-body">
            <p class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-[var(--fg-muted)]">
              {stationCode(i)}
            </p>
            <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-2">
              <h3 class="text-lg leading-tight text-[var(--fg)] sm:text-xl">
                {zone.name}
              </h3>
              <span class="capacity-chip" aria-label={`${zone.name} ${zone.capacity}`}>
                <span class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-[var(--fg-muted)]">
                  cap
                </span>
                <span class="font-mono text-sm font-medium text-[var(--accent)]">
                  {zone.capacity}
                </span>
              </span>
            </div>
            <p class="mt-3 max-w-[26ch] text-sm leading-relaxed text-[var(--fg-muted)]">
              {zone.desc}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Reveal delay hook (cooperates with the global [data-reveal] observer) ── */
  @media (prefers-reduced-motion: no-preference) {
    .station[data-reveal] {
      transition-delay: var(--reveal-delay, 0ms);
    }
  }

  /* ════════════════════════════════════════════════════════════════════
     MOBILE-FIRST: vertical line map.
     A single bold cyan rail runs down the left; stations stack beside it.
     ════════════════════════════════════════════════════════════════════ */
  .line-map {
    position: relative;
    display: grid;
    gap: 2.5rem;
  }

  /* The vertical connecting line (the "Metro line"). */
  .line-map::before {
    content: "";
    position: absolute;
    top: 1.5rem;
    bottom: 1.5rem;
    left: 1.5rem; /* centered under the 3rem-wide node */
    width: 3px;
    transform: translateX(-50%);
    background: var(--accent-fill);
    border-radius: 2px;
  }

  .station {
    position: relative;
    display: grid;
    grid-template-columns: 3rem 1fr;
    column-gap: 1.25rem;
    align-items: start;
  }

  .station-node {
    display: flex;
    justify-content: center;
  }

  /* The disc that sits on the line at each stop. */
  .node-ring {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 9999px;
    background: var(--bg);
    border: 3px solid var(--accent-fill);
  }

  .station-body {
    padding-top: 0.1rem;
  }

  .capacity-chip {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 9999px;
    line-height: 1;
  }

  /* ════════════════════════════════════════════════════════════════════
     DESKTOP (>= 768px): horizontal line map.
     Four stations evenly spaced across a single bold horizontal line;
     each station's body sits beneath its node.
     ════════════════════════════════════════════════════════════════════ */
  @media (min-width: 768px) {
    .line-map {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      column-gap: 1.5rem;
    }

    /* Horizontal connecting line, threaded through the node centers.
       Stations are a 4-col grid with 1.5rem gaps; each node is centered in
       its column, so a node center sits one half-column in from each edge.
       Inset the line by half a column so it starts/ends at the end nodes. */
    .line-map::before {
      top: 1.5rem;
      bottom: auto;
      left: 0;
      right: 0;
      width: auto;
      height: 3px;
      margin-inline: calc((100% - 3 * 1.5rem) / 8);
      transform: translateY(-50%);
    }

    .station {
      grid-template-columns: 1fr;
      row-gap: 1.25rem;
      justify-items: center;
      text-align: left;
    }

    .station-body {
      width: 100%;
      max-width: 15rem;
      padding-top: 0;
    }
  }
</style>
