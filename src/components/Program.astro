---
// Program.astro
// Real run of show from the programming sheet. The section keeps the existing
// blueprint/metro visual language, but now renders timed sessions instead of
// the earlier generic venue-zone map.

import { getLang, useTranslations } from '../i18n/utils';
import Pictogram from './primitives/Pictogram.astro';

const lang = getLang(Astro);
const t = useTranslations(lang);
const p = t.program;

type Track = keyof typeof p.tracks;
type Session = {
  track: Track;
  title: string;
  desc?: string;
};
type Slot = {
  time: string;
  sessions: readonly Session[];
};

const timeline = p.timeline as readonly Slot[];

const isSingleTrack = (slot: Slot) => slot.sessions.length === 1;

const hasDescription = (session: Session) => Boolean(session.desc);
---

<section
  id="programa"
  class="relative border-t border-[var(--border)] bg-[var(--bg)] py-24 md:py-32"
>
  <div class="mx-auto max-w-[1200px] px-6">
    <header class="program-header gap-10" data-reveal>
      <div class="max-w-2xl">
        <p class="mb-5 font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">
          <span class="text-[var(--cta)]">+</span> {p.eyebrow}
        </p>
        <h2 class="text-balance text-3xl leading-[1.05] sm:text-4xl md:text-5xl">
          {p.head}
        </h2>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-[var(--fg-muted)]">
          {p.sub}
        </p>
      </div>

      <dl class="program-facts" aria-label={p.eyebrow}>
        {p.facts.map((fact) => (
          <div class="fact-row">
            <dt class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-[var(--fg-muted)]">
              {fact.label}
            </dt>
            <dd class="mt-1 text-sm leading-snug text-[var(--fg)]">
              {fact.value}
            </dd>
          </div>
        ))}
      </dl>
    </header>

    <div class="agenda mt-14 md:mt-16" role="list" aria-label={p.head}>
      {timeline.map((slot, i) => (
        <article
          class:list={['agenda-slot', isSingleTrack(slot) && 'single-track']}
          role="listitem"
          data-reveal
          style={`--reveal-delay:${i * 55}ms`}
        >
          <time class="slot-time" datetime={`2026-07-09T${slot.time}:00-06:00`}>
            {slot.time}
          </time>

          <div class="session-grid">
            {slot.sessions.map((session) => (
              <div class:list={['session-card', `track-${session.track}`]}>
                <div class="session-track">
                  <Pictogram
                    name={session.track}
                    class="h-4 w-4 shrink-0 text-[var(--accent)]"
                    title={p.tracks[session.track]}
                  />
                  <span>{p.tracks[session.track]}</span>
                </div>

                <h3 class="mt-4 text-xl leading-snug text-[var(--fg)] sm:text-2xl">
                  {session.title}
                </h3>

                {hasDescription(session) && (
                  <p class="session-desc">
                    {session.desc}
                  </p>
                )}
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .agenda-slot[data-reveal] {
      transition-delay: var(--reveal-delay, 0ms);
    }
  }

  .program-header {
    display: grid;
    align-items: end;
  }

  .program-facts {
    border-top: 1px solid var(--border);
  }

  .fact-row {
    display: grid;
    gap: 0.125rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .agenda {
    position: relative;
    display: grid;
    gap: 0.75rem;
  }

  .agenda::before {
    content: "";
    position: absolute;
    top: 0.75rem;
    bottom: 0.75rem;
    left: 0.375rem;
    width: 3px;
    background: var(--accent-fill);
    border-radius: 2px;
  }

  .agenda-slot {
    position: relative;
    display: grid;
    gap: 0.75rem;
    padding-left: 1.75rem;
  }

  .agenda-slot::before {
    content: "";
    position: absolute;
    top: 0.72rem;
    left: 0;
    width: 0.8rem;
    height: 0.8rem;
    border: 3px solid var(--accent-fill);
    border-radius: 9999px;
    background: var(--bg);
  }

  .slot-time {
    align-self: start;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }

  .session-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .session-card {
    min-height: 10.25rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent-fill);
    border-radius: 2px;
    background: var(--surface);
    padding: 1.15rem;
  }

  .session-track {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--fg-muted);
  }

  .session-desc {
    margin-top: 1rem;
    max-width: 46ch;
    font-size: 0.98rem;
    line-height: 1.45;
    color: var(--fg-muted);
  }

  @media (min-width: 768px) {
    .program-header {
      grid-template-columns: minmax(0, 1fr) minmax(16rem, 24rem);
    }

    .agenda {
      gap: 1rem;
    }

    .agenda::before {
      left: 5.4rem;
    }

    .agenda-slot {
      grid-template-columns: 4.5rem minmax(0, 1fr);
      gap: 1.5rem;
      padding-left: 0;
    }

    .agenda-slot::before {
      left: 5.025rem;
    }

    .slot-time {
      padding-top: 0.65rem;
      text-align: right;
    }

    .session-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .single-track .session-card {
      grid-column: 1 / -1;
      min-height: 7.75rem;
    }
  }
</style>
