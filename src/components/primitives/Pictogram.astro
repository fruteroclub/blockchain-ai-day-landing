---
// Pictogram.astro
// Bold single-weight geometric pictograms in the Lance Wyman / CDMX Metro
// spirit. One clear idea per mark. Inline SVG, stroke="currentColor" so the
// caller sets color via a text utility (e.g. text-[var(--accent)]).
//
// 48x48 viewBox, strokeWidth ~6, square caps/joins. Decorative by default
// (aria-hidden); pass a `title` to expose an accessible label.

type Name =
  | 'main'
  | 'workshop'
  | 'cinema'
  | 'cowork'
  | 'transformer'
  | 'blockchain'
  | 'zkml'
  | 'depin';

interface Props {
  name: Name;
  class?: string;
  title?: string;
}
const { name, class: className = '', title } = Astro.props;
const labelled = Boolean(title);
---

<svg
  class={className}
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="6"
  stroke-linecap="square"
  stroke-linejoin="miter"
  role={labelled ? 'img' : undefined}
  aria-hidden={labelled ? undefined : 'true'}
  aria-label={labelled ? title : undefined}
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  {title && <title>{title}</title>}

  {/* main stage: a podium / proscenium, one speaker mark above a base rule */}
  {name === 'main' && (
    <>
      <circle cx="24" cy="13" r="5" fill="currentColor" stroke="none" />
      <path d="M10 40 L24 24 L38 40" />
      <path d="M7 40 H41" />
    </>
  )}

  {/* workshop: a bold wrench/tool angle over a worktable */}
  {name === 'workshop' && (
    <>
      <path d="M9 9 L24 24" />
      <path d="M24 24 L39 9" />
      <path d="M24 24 V41" />
      <path d="M8 41 H40" />
    </>
  )}

  {/* cinema: projector beam triangle into a screen frame */}
  {name === 'cinema' && (
    <>
      <circle cx="13" cy="24" r="5" fill="currentColor" stroke="none" />
      <path d="M18 18 L40 11" />
      <path d="M18 30 L40 37" />
      <path d="M40 11 V37" />
    </>
  )}

  {/* cowork: a long table with two seats facing each other */}
  {name === 'cowork' && (
    <>
      <circle cx="13" cy="13" r="4.5" fill="currentColor" stroke="none" />
      <circle cx="35" cy="13" r="4.5" fill="currentColor" stroke="none" />
      <path d="M8 28 H40" />
      <path d="M14 28 V40" />
      <path d="M34 28 V40" />
    </>
  )}

  {/* transformer / AI: stacked attention layers feeding a core node */}
  {name === 'transformer' && (
    <>
      <path d="M8 10 H40" />
      <path d="M8 38 H40" />
      <path d="M14 10 L24 24 L34 10" />
      <path d="M14 38 L24 24 L34 38" />
      <circle cx="24" cy="24" r="3.5" fill="currentColor" stroke="none" />
    </>
  )}

  {/* blockchain: three linked blocks in a chain */}
  {name === 'blockchain' && (
    <>
      <rect x="6" y="18" width="12" height="12" />
      <rect x="30" y="18" width="12" height="12" />
      <path d="M18 24 H30" />
      <path d="M24 6 V18" />
      <path d="M24 30 V42" />
    </>
  )}

  {/* zkml: a shield with an inner inference node (verified inference) */}
  {name === 'zkml' && (
    <>
      <path d="M24 7 L40 13 V25 C40 34 33 39 24 42 C15 39 8 34 8 25 V13 Z" />
      <circle cx="24" cy="24" r="3.5" fill="currentColor" stroke="none" />
      <path d="M18 24 H30" />
    </>
  )}

  {/* depin: a central hub wired to distributed physical nodes */}
  {name === 'depin' && (
    <>
      <circle cx="24" cy="24" r="4" fill="currentColor" stroke="none" />
      <path d="M24 24 L11 11" />
      <path d="M24 24 L37 11" />
      <path d="M24 24 L11 37" />
      <path d="M24 24 L37 37" />
      <rect x="6" y="6" width="6" height="6" fill="currentColor" stroke="none" />
      <rect x="36" y="6" width="6" height="6" fill="currentColor" stroke="none" />
      <rect x="6" y="36" width="6" height="6" fill="currentColor" stroke="none" />
      <rect x="36" y="36" width="6" height="6" fill="currentColor" stroke="none" />
    </>
  )}
</svg>
