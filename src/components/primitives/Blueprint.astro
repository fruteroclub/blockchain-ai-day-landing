---
// Blueprint.astro
// Decorative radial "inference blueprint" backdrop in the Lance Wyman /
// Mexico 68 spirit: concentric arcs + radiating lines + a ring of small
// hexagons, drawn in thin strokes via stroke="currentColor" so callers set
// the color through a text utility, e.g. text-[var(--accent)].
//
// Sanctioned custom SVG (the only one besides Pictogram). Decorative and
// non-interactive: pointer-events-none + aria-hidden. No animation here; the
// hero may layer its own CSS line-draw on top.

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

// 200x200 viewBox centered at 100,100.
const cx = 100;
const cy = 100;

// Concentric arc radii.
const rings = [28, 46, 64, 82, 96];

// Radiating lines: 24 spokes from an inner radius out to the edge.
const spokes = Array.from({ length: 24 }, (_, i) => {
  const a = (i / 24) * Math.PI * 2 - Math.PI / 2;
  const r0 = 30;
  const r1 = 92;
  return {
    x1: cx + Math.cos(a) * r0,
    y1: cy + Math.sin(a) * r0,
    x2: cx + Math.cos(a) * r1,
    y2: cy + Math.sin(a) * r1,
  };
});

// Ring of small hexagons (blockchain validation ring) at radius 70.
const hexRing = 70;
const hexCount = 12;
const hexR = 6.5;
function hexPath(hx: number, hy: number, r: number): string {
  const pts: string[] = [];
  for (let i = 0; i < 6; i++) {
    const a = (i / 6) * Math.PI * 2 - Math.PI / 2;
    pts.push(`${(hx + Math.cos(a) * r).toFixed(2)},${(hy + Math.sin(a) * r).toFixed(2)}`);
  }
  return `M ${pts.join(' L ')} Z`;
}
const hexes = Array.from({ length: hexCount }, (_, i) => {
  const a = (i / hexCount) * Math.PI * 2;
  const hx = cx + Math.cos(a) * hexRing;
  const hy = cy + Math.sin(a) * hexRing;
  return hexPath(hx, hy, hexR);
});
---

<svg
  class={`pointer-events-none ${className}`}
  viewBox="0 0 200 200"
  fill="none"
  stroke="currentColor"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- concentric arcs -->
  {rings.map((r, i) => (
    <circle
      cx={cx}
      cy={cy}
      r={r}
      stroke-width={i === rings.length - 1 ? 1.25 : 0.75}
      opacity={i === rings.length - 1 ? 0.9 : 0.5}
    />
  ))}

  <!-- radiating spokes -->
  {spokes.map((s) => (
    <line x1={s.x1} y1={s.y1} x2={s.x2} y2={s.y2} stroke-width="0.5" opacity="0.4" />
  ))}

  <!-- hexagon validation ring -->
  {hexes.map((d) => (
    <path d={d} stroke-width="1" opacity="0.85" />
  ))}

  <!-- transformer core -->
  <circle cx={cx} cy={cy} r="10" stroke-width="1.5" opacity="0.95" />
  <circle cx={cx} cy={cy} r="2.5" fill="currentColor" stroke="none" opacity="0.95" />
</svg>
