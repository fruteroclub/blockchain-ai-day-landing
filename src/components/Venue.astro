---
// Venue.astro
// Section id="sede". The single image+text split on the page.
// Layout family: split with map (left = address/when/arrive text column,
// right = a bordered map slot). Distinct from the hero split by its asymmetric
// 5/7 column ratio, cyan hairline framing, and mono blueprint annotations.
// Cyan = structure/line-work. No rosa moment here (no clear CTA job in this section).

import { Icon } from 'astro-icon/components';
import { getLang, useTranslations } from '../i18n/utils';

const lang = getLang(Astro);
const t = useTranslations(lang);
const v = t.venue;
---

<section id="sede" class="border-t border-[var(--border)] bg-[var(--bg)]">
  <div class="mx-auto max-w-[1200px] px-6 py-24 md:py-32">
    <div class="venue-grid grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-16">
      <!-- LEFT: text column -->
      <div class="md:col-span-5" data-reveal>
        <h2 class="text-4xl tracking-tight text-[var(--fg)] sm:text-5xl">
          {v.head}
        </h2>

        <!-- address -->
        <address class="mt-8 not-italic">
          <p class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-[var(--accent)]">
            <Icon name="ph:map-pin-bold" class="mb-0.5 inline-block h-4 w-4" aria-hidden="true" />
            <span class="ml-1.5">N 19.4326 / W 99.1332</span>
          </p>
          <div class="mt-3 space-y-1 text-lg leading-snug text-[var(--fg)]">
            {v.addressLines.map((line) => <p>{line}</p>)}
          </div>
        </address>

        <!-- when + arrive: stacked annotated rows, cyan hairline rule between -->
        <dl class="mt-10 border-t border-[var(--border)]">
          <div class="flex flex-col gap-2 border-b border-[var(--border)] py-5 sm:flex-row sm:items-baseline sm:gap-6">
            <dt class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-[var(--fg-muted)] sm:w-28 sm:shrink-0">
              <Icon name="ph:calendar-blank-bold" class="mb-0.5 mr-1.5 inline-block h-4 w-4 text-[var(--accent)]" aria-hidden="true" />
              {lang === 'es' ? 'Cuándo' : 'When'}
            </dt>
            <dd class="text-[var(--fg)]">{v.when}</dd>
          </div>
          <div class="flex flex-col gap-2 py-5 sm:flex-row sm:items-baseline sm:gap-6">
            <dt class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-[var(--fg-muted)] sm:w-28 sm:shrink-0">
              <Icon name="ph:train-bold" class="mb-0.5 mr-1.5 inline-block h-4 w-4 text-[var(--accent)]" aria-hidden="true" />
              {lang === 'es' ? 'Cómo llegar' : 'Getting here'}
            </dt>
            <dd class="text-[var(--fg-muted)]">{v.arrive}</dd>
          </div>
        </dl>
      </div>

      <!-- RIGHT: map slot, cyan hairline frame -->
      <div class="md:col-span-7" data-reveal>
        <figure class="map-frame relative h-full">
          <!-- corner ticks: blueprint registration marks -->
          <span class="tick tick-tl" aria-hidden="true"></span>
          <span class="tick tick-tr" aria-hidden="true"></span>
          <span class="tick tick-bl" aria-hidden="true"></span>
          <span class="tick tick-br" aria-hidden="true"></span>

          <div class="overflow-hidden border border-[var(--accent-fill)]">
            <!-- TODO: replace with a real embedded map of Jose Maria Izazaga 8, Centro Historico -->
            <img
              src="https://picsum.photos/seed/cdmx-centro-historico-map/800/600"
              alt={v.mapAlt}
              loading="lazy"
              width="800"
              height="600"
              class="aspect-[4/3] w-full object-cover"
            />
          </div>
          <figcaption class="mt-3 flex items-center gap-2 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-[var(--fg-muted)]">
            <span class="inline-block h-px w-6 bg-[var(--accent-fill)]"></span>
            Centro Histórico, CDMX
          </figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>

<style>
  /* Map frame: cyan registration ticks at the four corners, blueprint style. */
  .map-frame .tick {
    position: absolute;
    width: 12px;
    height: 12px;
    z-index: 1;
    pointer-events: none;
    border-color: var(--accent-fill);
    border-style: solid;
    border-width: 0;
  }
  .tick-tl {
    top: -4px;
    left: -4px;
    border-top-width: 1.5px;
    border-left-width: 1.5px;
  }
  .tick-tr {
    top: -4px;
    right: -4px;
    border-top-width: 1.5px;
    border-right-width: 1.5px;
  }
  .tick-bl {
    bottom: 28px;
    left: -4px;
    border-bottom-width: 1.5px;
    border-left-width: 1.5px;
  }
  .tick-br {
    bottom: 28px;
    right: -4px;
    border-bottom-width: 1.5px;
    border-right-width: 1.5px;
  }
</style>
