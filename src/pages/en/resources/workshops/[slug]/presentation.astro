---
import PresentationLayout from '../../../../../layouts/PresentationLayout.astro';
import WorkshopPresentation from '../../../../../components/WorkshopPresentation.astro';
import {
  getWorkshopCopy,
  getWorkshopSlides,
  workshopResources,
  type WorkshopResource,
} from '../../../../../data/workshops';

const lang = 'en';

export function getStaticPaths() {
  const pathLang = 'en';

  return workshopResources
    .filter((workshop) => getWorkshopSlides(workshop, pathLang))
    .map((workshop) => ({
      params: { slug: workshop.slug },
      props: { workshop },
    }));
}

const { workshop } = Astro.props as { workshop: WorkshopResource };
const copy = getWorkshopCopy(workshop, lang);
---

<PresentationLayout
  lang={lang}
  title={`${copy.title} | AI x Blockchain Day`}
  description={`Presentation mode for ${copy.title}, ${workshop.time} workshop at AI x Blockchain Day.`}
  ogImage={`/social/workshop-${workshop.number}-presentation-og-en.png`}
  ogImageAlt={`${copy.title} workshop presentation for AI x Blockchain Day.`}
  ogImageWidth={1200}
  ogImageHeight={630}
>
  <WorkshopPresentation workshop={workshop} lang={lang} />
</PresentationLayout>
