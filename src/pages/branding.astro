---
// Brand & Design System reference page. A living style guide driven by the real
// design system: src/styles/global.css tokens + the Blueprint / Pictogram
// primitives. Self-contained (its own head), dark-locked, noindex (internal
// reference). The logo section serves the current reference mark and leaves a
// slot for the official logo (drop it into public/brand/).
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import Blueprint from '../components/primitives/Blueprint.astro';
import Pictogram from '../components/primitives/Pictogram.astro';
import { event } from '../i18n/ui';

const neutral: [string, string][] = [
  ['n-950', '#0A0F16'], ['n-900', '#0E141D'], ['n-850', '#141D28'], ['n-800', '#1C2836'],
  ['n-700', '#283747'], ['n-500', '#5C7080'], ['n-400', '#8198A4'], ['n-300', '#A9BBC4'],
  ['n-200', '#C9D6DC'], ['n-100', '#E9EFF1'], ['n-50', '#F2F6F7'], ['n-0', '#F8FBFB'],
];
const cyan: [string, string][] = [['cyan-400', '#5FE3DA'], ['cyan-500', '#34C9C0'], ['cyan-700', '#0B6863']];
const rosa: [string, string][] = [['rosa-400', '#FF2E9A'], ['rosa-500', '#E6007E'], ['rosa-600', '#C7006B']];

const semantic: [string, string, string][] = [
  ['--bg', 'page background', 'n-900'],
  ['--surface', 'cards / bands', 'n-850'],
  ['--surface-2', 'raised / feature', 'n-800'],
  ['--border', 'hairlines, rules', 'n-700'],
  ['--fg', 'primary text', 'n-50'],
  ['--fg-muted', 'secondary text', 'n-300'],
  ['--accent', 'cyan text / links', 'cyan-400'],
  ['--accent-fill', 'cyan lines / fills', 'cyan-500'],
  ['--cta', 'Register CTA fill', 'rosa-500'],
  ['--cta-label', 'label on rosa', 'n-0'],
  ['--cta-press', 'CTA hover / active', 'rosa-600'],
];

type PName = 'main' | 'workshop' | 'cinema' | 'cowork' | 'transformer' | 'blockchain' | 'zkml' | 'depin';
const zones: { name: PName; label: string; cap: string }[] = [
  { name: 'main', label: 'Escenario', cap: '80' },
  { name: 'workshop', label: 'Taller', cap: '20' },
  { name: 'cinema', label: 'Cinema', cap: '20' },
  { name: 'cowork', label: 'Cowork', cap: '40-60' },
];
const themes: PName[] = ['transformer', 'blockchain', 'zkml', 'depin'];

const logoRef = '/brand/logo-ai-x-blockchain-day-reference.png';
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Marca y Design System · Blockchain + AI Day</title>
    <meta name="description" content="Referencia de marca y sistema de diseño de Blockchain + AI Day: paleta, tipografía, iconografía, componentes y logo." />
  </head>
  <body class="min-h-[100dvh] bg-[var(--bg)] text-[var(--fg)]">
    <main class="mx-auto max-w-[1200px] px-6 py-20">
      <!-- Header -->
      <header class="relative overflow-hidden border-b border-[var(--border)] pb-14">
        <Blueprint class="pointer-events-none absolute -right-24 -top-24 h-[28rem] w-[28rem] text-[var(--accent)] opacity-[0.10]" />
        <p class="relative font-mono text-xs uppercase tracking-[0.2em] text-[var(--accent)]">
          <span class="text-[var(--cta)]">+</span> Marca / Design System
        </p>
        <h1 class="relative mt-4 max-w-[20ch] text-4xl font-semibold tracking-tight sm:text-5xl">
          Blockchain + AI Day
        </h1>
        <p class="relative mt-4 max-w-[60ch] text-[var(--fg-muted)]">
          Referencia viva del sistema de diseño: paleta, tipografía, iconografía, componentes y logo.
          Todo deriva de <code class="font-mono text-[var(--accent)]">src/styles/global.css</code> y de
          <code class="font-mono text-[var(--accent)]">DESIGN.md</code>.
        </p>
      </header>

      <!-- Logo -->
      <section class="border-b border-[var(--border)] py-16">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">Logo</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">Marca</h2>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          <figure class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-6">
            <div class="flex items-center justify-center rounded-sm bg-[var(--color-n-950)] p-6">
              <img src={logoRef} alt="Logo de referencia Blockchain + AI Day" class="h-auto w-full max-w-[420px]" />
            </div>
            <figcaption class="mt-4 flex flex-wrap items-center justify-between gap-3">
              <span class="font-mono text-xs uppercase tracking-[0.14em] text-[var(--fg-muted)]">
                Referencia actual · &quot;Plano de inferencia verificable&quot;
              </span>
              <a
                href={logoRef}
                download
                class="inline-flex items-center gap-2 rounded-sm border border-[var(--accent-fill)] px-3 py-1.5 font-mono text-xs uppercase tracking-wide text-[var(--accent)] transition-colors hover:bg-[var(--accent-fill)]/10"
              >
                Descargar PNG
              </a>
            </figcaption>
          </figure>

          <figure class="flex flex-col rounded-sm border border-dashed border-[var(--border)] bg-[var(--surface)] p-6">
            <div class="flex flex-1 items-center justify-center rounded-sm border border-dashed border-[var(--border)] p-10 text-center">
              <span class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--fg-muted)]">
                Logo oficial<br />en proceso
              </span>
            </div>
            <figcaption class="mt-4 font-mono text-xs uppercase tracking-[0.14em] text-[var(--fg-muted)]">
              Coloca el archivo final en <code>public/brand/</code> y reemplaza esta tarjeta.
            </figcaption>
          </figure>
        </div>
        <p class="mt-6 max-w-[65ch] text-sm leading-relaxed text-[var(--fg-muted)]">
          El logo de referencia se lee como un plano tecnico: nucleo de inferencia (IA), anillo
          hexagonal de validacion (blockchain) y anotaciones con las coordenadas de CDMX
          (N 19.4326 / W 99.1332). El motivo geometrico radial es el mismo que el primitivo
          <code class="font-mono text-[var(--accent)]">Blueprint</code> usa en el sitio.
        </p>
      </section>

      <!-- Color -->
      <section class="border-b border-[var(--border)] py-16">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">Color</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">Paleta</h2>
        <p class="mt-3 max-w-[60ch] text-sm text-[var(--fg-muted)]">
          Una sola paleta. Dos acentos con roles fijos: cyan = IA / sistema / estructura;
          rosa mexicana = el CTA de registro y la marca &quot;+&quot;. Light y dark son la misma
          paleta remapeada por tokens semanticos (la pagina esta bloqueada en dark).
        </p>

        <h3 class="mt-10 font-mono text-xs uppercase tracking-[0.16em] text-[var(--fg-muted)]">Neutral ramp</h3>
        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-6">
          {neutral.map(([name, hex]) => (
            <div class="rounded-sm border border-[var(--border)] overflow-hidden">
              <div class="h-16" style={`background:${hex}`}></div>
              <div class="bg-[var(--surface)] px-3 py-2">
                <div class="font-mono text-[11px] text-[var(--fg)]">{name}</div>
                <div class="font-mono text-[11px] text-[var(--fg-muted)]">{hex}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 grid gap-8 sm:grid-cols-2">
          <div>
            <h3 class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--fg-muted)]">Cyan · AI / system</h3>
            <div class="mt-4 grid grid-cols-3 gap-3">
              {cyan.map(([name, hex]) => (
                <div class="rounded-sm border border-[var(--border)] overflow-hidden">
                  <div class="h-16" style={`background:${hex}`}></div>
                  <div class="bg-[var(--surface)] px-3 py-2">
                    <div class="font-mono text-[11px] text-[var(--fg)]">{name}</div>
                    <div class="font-mono text-[11px] text-[var(--fg-muted)]">{hex}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div>
            <h3 class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--fg-muted)]">Rosa mexicana · CTA</h3>
            <div class="mt-4 grid grid-cols-3 gap-3">
              {rosa.map(([name, hex]) => (
                <div class="rounded-sm border border-[var(--border)] overflow-hidden">
                  <div class="h-16" style={`background:${hex}`}></div>
                  <div class="bg-[var(--surface)] px-3 py-2">
                    <div class="font-mono text-[11px] text-[var(--fg)]">{name}</div>
                    <div class="font-mono text-[11px] text-[var(--fg-muted)]">{hex}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <h3 class="mt-10 font-mono text-xs uppercase tracking-[0.16em] text-[var(--fg-muted)]">Tokens semanticos (dark)</h3>
        <div class="mt-4 overflow-hidden rounded-sm border border-[var(--border)]">
          <table class="w-full border-collapse text-left">
            <thead>
              <tr class="bg-[var(--surface)] font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--fg-muted)]">
                <th class="px-4 py-2 font-medium">token</th>
                <th class="px-4 py-2 font-medium">rol</th>
                <th class="px-4 py-2 font-medium">valor</th>
                <th class="px-4 py-2 font-medium"></th>
              </tr>
            </thead>
            <tbody>
              {semantic.map(([token, role, val]) => (
                <tr class="border-t border-[var(--border)]">
                  <td class="px-4 py-2 font-mono text-xs text-[var(--accent)]">{token}</td>
                  <td class="px-4 py-2 text-xs text-[var(--fg-muted)]">{role}</td>
                  <td class="px-4 py-2 font-mono text-xs text-[var(--fg)]">{val}</td>
                  <td class="px-4 py-2"><span class="inline-block h-4 w-8 rounded-[2px] border border-[var(--border)]" style={`background:var(${token})`}></span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Typography -->
      <section class="border-b border-[var(--border)] py-16">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">Tipografia</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">Tipografia</h2>
        <div class="mt-8 grid gap-8 md:grid-cols-2">
          <div class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-6">
            <div class="font-mono text-xs uppercase tracking-[0.14em] text-[var(--fg-muted)]">Display / Sans · Space Grotesk</div>
            <p class="mt-4 text-4xl font-semibold tracking-tight">Donde la inferencia se vuelve verificable.</p>
            <p class="mt-4 text-base leading-relaxed text-[var(--fg-muted)]">
              Cuerpo de texto en Space Grotesk. AaBbCc 0123456789 áéíóú ñ ¿? ¡!
            </p>
          </div>
          <div class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-6">
            <div class="font-mono text-xs uppercase tracking-[0.14em] text-[var(--fg-muted)]">Mono · JetBrains Mono</div>
            <p class="mt-4 font-mono text-lg text-[var(--accent)]">JUE 09 JUL 2026 · 11:00 a 19:00 · CDMX</p>
            <p class="mt-3 font-mono text-sm text-[var(--fg-muted)]">N 19.4326 / W 99.1332 · DEPIN_MEX_NODO_03</p>
            <p class="mt-3 font-mono text-xs uppercase tracking-[0.18em] text-[var(--fg-muted)]">Anotaciones blueprint</p>
          </div>
        </div>
      </section>

      <!-- Iconography -->
      <section class="border-b border-[var(--border)] py-16">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">Iconografia</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">Pictogramas (Wyman)</h2>
        <p class="mt-3 max-w-[60ch] text-sm text-[var(--fg-muted)]">
          Marcas geometricas de un solo trazo, en el espiritu de Lance Wyman (Mexico 68 + Metro CDMX).
          Color via <code class="font-mono text-[var(--accent)]">currentColor</code>.
        </p>

        <h3 class="mt-8 font-mono text-xs uppercase tracking-[0.16em] text-[var(--fg-muted)]">Zonas del programa</h3>
        <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
          {zones.map((z) => (
            <div class="flex flex-col items-center gap-3 rounded-sm border border-[var(--border)] bg-[var(--surface)] p-6 text-[var(--accent)]">
              <Pictogram name={z.name} title={z.label} class="h-10 w-10" />
              <div class="text-center">
                <div class="text-sm text-[var(--fg)]">{z.label}</div>
                <div class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--fg-muted)]">cap {z.cap}</div>
              </div>
            </div>
          ))}
        </div>

        <h3 class="mt-8 font-mono text-xs uppercase tracking-[0.16em] text-[var(--fg-muted)]">Temas tecnicos</h3>
        <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
          {themes.map((t) => (
            <div class="flex flex-col items-center gap-3 rounded-sm border border-[var(--border)] bg-[var(--surface)] p-6 text-[var(--accent)]">
              <Pictogram name={t} title={t} class="h-10 w-10" />
              <div class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--fg-muted)]">{t}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- Blueprint -->
      <section class="border-b border-[var(--border)] py-16">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">Motivo</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">Blueprint</h2>
        <p class="mt-3 max-w-[60ch] text-sm text-[var(--fg-muted)]">
          Fondo radial de &quot;inferencia&quot;: arcos concentricos, radios, anillo de hexagonos y nucleo.
          Decorativo, a baja opacidad, detras del contenido.
        </p>
        <div class="mt-6 flex justify-center rounded-sm border border-[var(--border)] bg-[var(--surface)] p-10 text-[var(--accent)]">
          <Blueprint class="h-72 w-72" />
        </div>
      </section>

      <!-- Components -->
      <section class="border-b border-[var(--border)] py-16">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">Componentes</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">Componentes</h2>

        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          <div class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-6">
            <div class="font-mono text-xs uppercase tracking-[0.14em] text-[var(--fg-muted)]">Button</div>
            <div class="mt-5 flex flex-wrap items-center gap-3">
              <a href="#" class="inline-flex items-center gap-2 rounded-sm bg-[var(--cta)] px-6 py-3 font-mono text-sm font-medium uppercase tracking-wide text-[var(--cta-label)] transition-colors hover:bg-[var(--cta-press)]">Registrarme</a>
              <a href="#" class="inline-flex items-center gap-2 rounded-sm border border-[var(--accent-fill)] px-6 py-3 font-mono text-sm font-medium uppercase tracking-wide text-[var(--accent)] transition-colors hover:bg-[var(--accent-fill)]/10">Ver el programa</a>
            </div>
            <p class="mt-4 font-mono text-[11px] text-[var(--fg-muted)]">primary (rosa) · secondary (cyan outline) · mono uppercase</p>
          </div>

          <div class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-6">
            <div class="font-mono text-xs uppercase tracking-[0.14em] text-[var(--fg-muted)]">Eyebrow</div>
            <div class="mt-5 space-y-3">
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]"><span class="text-[var(--cta)]">+</span> Programa</p>
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">Que es</p>
            </div>
            <p class="mt-4 font-mono text-[11px] text-[var(--fg-muted)]">mono label, opcional marca rosa &quot;+&quot;</p>
          </div>
        </div>

        <div class="mt-6 rounded-sm border border-[var(--border)] bg-[var(--surface)] p-8">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]"><span class="text-[var(--cta)]">+</span> Programa</p>
          <h3 class="mt-3 text-3xl font-semibold tracking-tight">Cuatro zonas, un solo dia.</h3>
          <p class="mt-3 max-w-[60ch] text-[var(--fg-muted)]">El espacio se organiza como un mapa de lineas: cada zona con su aforo y su ritmo.</p>
          <a href="#" class="mt-5 inline-flex items-center gap-2 rounded-sm bg-[var(--cta)] px-6 py-3 font-mono text-sm font-medium uppercase tracking-wide text-[var(--cta-label)] transition-colors hover:bg-[var(--cta-press)]">Registrarme</a>
          <p class="mt-4 font-mono text-[11px] text-[var(--fg-muted)]">Section: eyebrow + headline + body + CTA</p>
        </div>
      </section>

      <!-- Foundations -->
      <section class="py-16">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">Fundamentos</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">Reglas</h2>
        <ul class="mt-6 grid gap-3 text-sm text-[var(--fg-muted)] sm:grid-cols-2">
          <li class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-4"><span class="text-[var(--fg)]">Tema:</span> bloqueado en dark. Flip con <code class="font-mono text-[var(--accent)]">data-theme="light"</code>.</li>
          <li class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-4"><span class="text-[var(--fg)]">Radio:</span> <code class="font-mono">rounded-sm</code> (2px) en todo.</li>
          <li class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-4"><span class="text-[var(--fg)]">Acentos:</span> cyan = sistema/estructura; rosa = CTA y marca &quot;+&quot;. Nunca se cruzan.</li>
          <li class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-4"><span class="text-[var(--fg)]">Contenedor:</span> <code class="font-mono">max-w-[1200px]</code>, gutters <code class="font-mono">px-6</code>.</li>
          <li class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-4"><span class="text-[var(--fg)]">SVG custom:</span> solo Blueprint y Pictogram. Iconos: Phosphor (bold).</li>
          <li class="rounded-sm border border-[var(--border)] bg-[var(--surface)] p-4"><span class="text-[var(--fg)]">Sin em-dash</span> en ningun texto. Hyphen.</li>
        </ul>
        <p class="mt-8 font-mono text-xs text-[var(--fg-muted)]">
          Fuente de verdad: <code class="text-[var(--accent)]">src/styles/global.css</code> +
          <code class="text-[var(--accent)]">DESIGN.md</code>. Registro: {event.registrationUrl}
        </p>
      </section>
    </main>
  </body>
</html>
