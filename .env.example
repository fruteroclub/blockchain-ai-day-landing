# PostHog — product analytics, funnels, session replay (optional).
# Leave unset to disable PostHog entirely (the snippet won't load).
# Set it in Vercel → Project → Settings → Environment Variables (Production),
# then redeploy. Value looks like: phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Region note: this project proxies PostHog through /ingest (see vercel.json),
# pinned to US. For the EU cloud, change the hosts in vercel.json to
# eu(-assets).i.posthog.com and ui_host to https://eu.posthog.com in
# src/components/Analytics.astro.
PUBLIC_POSTHOG_KEY=
